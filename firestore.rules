rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required, < 100 chars)
    //   - stage: string (required, enum)
    //   - number: string (required, < 50 chars)
    //   - badges: map (required)
    //     - badge1, badge2, badge3: map
    //       - name: string (required)
    //       - progress: number (required, 0-100)
    //       - notes: string (optional, < 1000 chars)
    //   - role: string (required, 'scout' | 'admin')
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/settings/superadmins) && 
         request.auth.token.email in get(/databases/$(database)/documents/settings/superadmins).data.emails) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'scout') == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get('canManagePermissions', false) == true
        ))
      );
    }

    function isValidUser(data) {
      return (
        (!('uid' in data) || data.uid is string) &&
        (!('name' in data) || (data.name is string && data.name.size() > 0)) &&
        (!('stage' in data) || data.stage is string) &&
        (!('number' in data) || data.number is string) &&
        (!('role' in data) || data.role in ['scout', 'admin']) &&
        (!('badges' in data) || (
          data.badges is map &&
          isValidBadge(data.badges.get('badge1', {})) &&
          isValidBadge(data.badges.get('badge2', {})) &&
          isValidBadge(data.badges.get('badge3', {}))
        )) &&
        (!('permissions' in data) || data.permissions is map)
      );
    }

    function isValidBadge(badge) {
      return badge is map &&
        (!('name' in badge) || badge.name is string) &&
        (!('progress' in badge) || (badge.progress is number && badge.progress >= 0 && badge.progress <= 100)) &&
        (!('requirementScores' in badge) || badge.requirementScores is map) &&
        (!('completedRequirements' in badge) || badge.completedRequirements is list);
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/settings/superadmins) && 
         request.auth.token.email in get(/databases/$(database)/documents/settings/superadmins).data.emails) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get('canManagePermissions', false) == true
        ))
      );
    }

    function isValidActivityLog(data) {
      return (
        data.action is string &&
        data.details is string &&
        data.adminId is string &&
        data.adminName is string &&
        (!('targetUserId' in data) || data.targetUserId is string) &&
        (!('targetUserName' in data) || data.targetUserName is string) &&
        data.timestamp is timestamp
      );
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /activity_logs/{logId} {
      allow read: if isSuperAdmin();
      allow create: if isAdmin() && isValidActivityLog(request.resource.data) && request.resource.data.adminId == request.auth.uid;
      allow update: if false; // Logs are immutable
      allow delete: if isSuperAdmin();
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == 'scout') || 
        isAdmin()
      );
      
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() || (
          isOwner(userId) && 
          request.resource.data.role == resource.data.role &&
          // Scouts can update their own profile info but not their progress unless it's a new setup
          (
            (
              request.resource.data.badges.badge1.progress == resource.data.badges.badge1.progress &&
              request.resource.data.badges.badge2.progress == resource.data.badges.badge2.progress &&
              request.resource.data.badges.badge3.progress == resource.data.badges.badge3.progress
            ) ||
            // Allow setting progress to 0 if it was missing or already 0 (safety for profile completion)
            (
              request.resource.data.badges.badge1.progress == 0 &&
              request.resource.data.badges.badge2.progress == 0 &&
              request.resource.data.badges.badge3.progress == 0
            )
          )
        )
      );
      
      allow delete: if isAdmin() && (
        resource.data.role != 'admin' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get('canManagePermissions', false) == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get('canDeleteAccounts', false) == true ||
        (exists(/databases/$(database)/documents/settings/superadmins) && 
         request.auth.token.email in get(/databases/$(database)/documents/settings/superadmins).data.emails)
      );
    }
    match /deleted_accounts_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if false; // Logs generally shouldn't be edited
    }
    
    match /cancellationRequests/{requestId} {
      allow read: if isAdmin() || isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow delete: if isAdmin();
    }
  }
}
