rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required, < 100 chars)
    //   - stage: string (required, enum)
    //   - number: string (required, < 50 chars)
    //   - badges: map (required)
    //     - badge1, badge2, badge3: map
    //       - name: string (required)
    //       - progress: number (required, 0-100)
    //       - notes: string (optional, < 1000 chars)
    //   - role: string (required, 'scout' | 'admin')
    //   - createdAt: timestamp (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "begolbahaa98@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.number == '01555165366' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get('canManagePermissions', false) == true
        ))
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'stage', 'number', 'badges', 'role']) &&
        data.uid is string &&
        data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
        data.stage in ['أشبال وزهرات مبتدأ', 'أشبال وزهرات', 'كشاف ومرشدات', 'متقدم ورائدات', 'قادة وجوالة'] &&
        data.number is string && data.number.size() < 50 &&
        data.role in ['scout', 'admin'] &&
        (!('email' in data) || data.email is string) &&
        (!('createdAt' in data) || data.createdAt is timestamp) &&
        (!('isVerified' in data) || data.isVerified is bool) &&
        (!('joinDate' in data) || data.joinDate is timestamp) &&
        data.badges is map &&
        isValidBadge(data.badges.badge1) &&
        isValidBadge(data.badges.badge2) &&
        isValidBadge(data.badges.badge3);
    }

    function isValidBadge(badge) {
      return badge is map &&
        badge.name is string &&
        badge.progress is number && badge.progress >= 0 && badge.progress <= 100 &&
        (!('notes' in badge) || (badge.notes is string && badge.notes.size() < 1000)) &&
        (!('completedRequirements' in badge) || badge.completedRequirements is list) &&
        (!('requirementScores' in badge) || badge.requirementScores is map);
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (
        (isOwner(userId) && request.resource.data.role == 'scout') || 
        isAdmin()
      );
      
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        isAdmin() || (
          isOwner(userId) && 
          request.resource.data.role == resource.data.role &&
          // Scouts can update their own profile info but not their progress unless it's a new setup
          (
            (
              request.resource.data.badges.badge1.progress == resource.data.badges.badge1.progress &&
              request.resource.data.badges.badge2.progress == resource.data.badges.badge2.progress &&
              request.resource.data.badges.badge3.progress == resource.data.badges.badge3.progress
            ) ||
            // Allow setting progress to 0 if it was missing or already 0 (safety for profile completion)
            (
              request.resource.data.badges.badge1.progress == 0 &&
              request.resource.data.badges.badge2.progress == 0 &&
              request.resource.data.badges.badge3.progress == 0
            )
          )
        )
      );
      
      allow delete: if isAdmin() && (
        resource.data.role != 'admin' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get('canManagePermissions', false) == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get('canDeleteAccounts', false) == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.number == '01555165366' ||
        request.auth.token.email == "begolbahaa98@gmail.com"
      );
    }
  }
}
